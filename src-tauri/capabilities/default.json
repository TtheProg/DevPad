{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "DevPad: native open/save dialogs and reading/writing the text files the user picks.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [{ "path": "$HOME/**" }, { "path": "/**" }]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "$HOME/**" }, { "path": "/**" }]
    }
  ]
}
