{
  "name": "devpad",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Fast, offline, local-only developer scratchpad — JSON/YAML/CSV + Markdown tools. Web + native macOS app from one codebase.",
  "scripts": {
    "dev": "astro dev --port 4600",
    "build": "astro build",
    "preview": "astro preview --port 4600",
    "astro": "astro",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri": "tauri"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.7",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.1",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "astro": "^6.4.6",
    "codemirror": "^6.0.2",
    "dompurify": "^3.4.10",
    "js-yaml": "^4.2.0",
    "marked": "^18.0.5",
    "papaparse": "^5.5.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@tauri-apps/cli": "^2.11.2",
    "@types/js-yaml": "^4.0.9",
    "@types/papaparse": "^5.5.2",
    "vitest": "^4.1.8"
  },
  "comments": {
    "overrides": "Astro 6.4.6 expects Vite 7; npm otherwise pulls in rolldown-based Vite 8, whose TSX/transform plugins break the dev server ('Missing field moduleType')."
  },
  "overrides": {
    "vite": "^7"
  }
}
